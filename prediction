import re
from pathlib import Path

import joblib
import pandas as pd


def clean_text(text):
    if pd.isna(text):
        return ''
    text = str(text).lower()
    text = re.sub(r'[^a-z\s]', ' ', text)
    return re.sub(r'\s+', ' ', text).strip()


model_path = Path(__file__).resolve().with_name('spam_model.pkl')
vectorizer_path = Path(__file__).resolve().with_name('vectorizer.pkl')

if not model_path.exists() or not vectorizer_path.exists():
    raise FileNotFoundError('Model files not found. Run model_for_reuse first.')

model = joblib.load(model_path)
vectorizer = joblib.load(vectorizer_path)


def predict_spam(text):
    cleaned = clean_text(text)
    vec = vectorizer.transform([cleaned])
    pred = model.predict(vec)[0]
    return 'Spam' if pred == 1 else 'Not Spam'


print(predict_spam('Congratulations! You\'ve won a free iPhone, click here now!'))
print(predict_spam('Hey, are we still on for lunch tomorrow?'))